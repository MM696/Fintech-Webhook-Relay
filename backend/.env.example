# Node
TZ=UTC
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# App
APP_NAME=ezrah-webhook-relay
LOG_LEVEL=info
APP_KEY=
APP_URL=http://localhost:3333
API_SECRET_KEY=change-me-in-production

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=webhook_relay

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Session (required by starter kit; unused by webhook API)
SESSION_DRIVER=cookie

# CORS (configure allowed origins for frontend)
# CORS_ORIGIN=http://localhost:5173
